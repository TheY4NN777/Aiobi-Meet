<mj-section padding="0">
  <mj-column>
    <mj-divider border-width="1px" border-style="solid" border-color="#ebebf0" padding="0 40px" />
    <mj-text align="center" padding="20px 20px" font-size="12px" color="#8b8ba3">
      <p style="margin: 0;">
        {% blocktranslate with brandname=brandname trimmed %}
          Sent by {{brandname}} — Sovereign video conferencing for Africa
        {% endblocktranslate %}
      </p>
    </mj-text>
  </mj-column>
</mj-section>
