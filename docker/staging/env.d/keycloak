# Keycloak admin (Keycloak 20.x uses KEYCLOAK_ADMIN, not KC_BOOTSTRAP_ADMIN)
KEYCLOAK_ADMIN=${KC_BOOTSTRAP_ADMIN_USERNAME}
KEYCLOAK_ADMIN_PASSWORD=${KC_BOOTSTRAP_ADMIN_PASSWORD}

# Keycloak configuration
KC_HOSTNAME_URL=https://${MEET_HOST}:8443
KC_HOSTNAME_ADMIN_URL=https://${MEET_HOST}:8443
KC_PROXY=edge
KC_HTTP_ENABLED=true
