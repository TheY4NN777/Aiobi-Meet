# =============================================================================
# Summary service — Variables d'environnement (staging)
# Les secrets sont injectes via ${VAR} depuis le .env (non commite)
# =============================================================================

# --- App ---
APP_NAME=aiobi-meet-summary
APP_API_TOKEN=${SUMMARY_API_TOKEN}

# --- MinIO (memes credentials que le backend) ---
AWS_STORAGE_BUCKET_NAME=meet-media-storage
AWS_S3_ENDPOINT_URL=minio:9000
AWS_S3_ACCESS_KEY_ID=${POSTGRES_USER}
AWS_S3_SECRET_ACCESS_KEY=${POSTGRES_PASSWORD}
AWS_S3_SECURE_ACCESS=false

# --- Celery (Redis dedie) ---
CELERY_BROKER_URL=redis://redis-summary:6379/0
CELERY_RESULT_BACKEND=redis://redis-summary:6379/0
TASK_TRACKER_REDIS_URL=redis://redis-summary:6379/0

# --- Whisper local (faster-whisper-server) ---
WHISPERX_BASE_URL=http://whisper:8000/v1
WHISPERX_API_KEY=local
WHISPERX_ASR_MODEL=Systran/faster-whisper-large-v3
WHISPERX_DEFAULT_LANGUAGE=fr
WHISPERX_ALLOWED_LANGUAGES=en,fr

# --- LLM (Phase 2 — desactive) ---
IS_SUMMARY_ENABLED=false

# --- Webhook mode Aiobi (upload MinIO + notify backend) ---
WEBHOOK_MODE=minio
WEBHOOK_URL=http://backend:8000/api/v1.0/recordings
WEBHOOK_API_TOKEN=${SUMMARY_API_TOKEN}

# --- Transcription output ---
TRANSCRIPTION_OUTPUT_PREFIX=transcriptions/

# --- Analytics (desactives en staging) ---
LANGFUSE_ENABLED=false
POSTHOG_ENABLED=false
SENTRY_IS_ENABLED=false
